# Copy to `.env` and fill in your values.

# ─── Flask ──────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
HOST=127.0.0.1
PORT=5000

# Required in production (32+ random characters each)
SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET_KEY=change-me-to-another-long-random-string
JWT_ACCESS_TOKEN_EXPIRES=43200

# Comma-separated origins for production (e.g. https://your-app.vercel.app)
# Leave empty in development to allow all origins.
CORS_ORIGINS=

# Max upload size in bytes (default 5MB)
MAX_UPLOAD_BYTES=5242880

# Dev-only: skip company domain verification (ignored in production)
INTERNMATCH_SKIP_COMPANY_VERIFY=0

# ─── MongoDB ────────────────────────────────────────────────────
# Local MongoDB Compass:
# MONGODB_URI=mongodb://127.0.0.1:27017
#
# MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<db_username>:<db_password>@internmatch.znueh91.mongodb.net/?retryWrites=true&w=majority&appName=internmatch
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=internmatch

# Legacy aliases (optional; MONGODB_* takes precedence)
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# MONGO_DB=internmatch
